# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.2.0
# ----------------------------------------------------------------------------

set -e

# Find the project base dir, i.e. the closest directory that contains a ".mvn" directory.
find_maven_basedir() {
  if [ -z "$1" ]; then
    echo "Path not specified to find_maven_basedir"
    return 1
  fi
  basedir="$1"
  wdir="$1"
  while [ "$wdir" != '/' ]; do
    if [ -d "$wdir"/.mvn ]; then
      basedir=$wdir
      break
    fi
    wdir=$(cd "$wdir/.." && pwd)
  done
  printf '%s' "$(cd "$basedir" && pwd)"
}

# concatenates all lines of a file
concat_lines() {
  if [ -f "$1" ]; then
    echo "$(tr -s '\n' ' ' <"$1")"
  fi
}

BASE_DIR=$(find_maven_basedir "$(dirname "$0")")
export MAVEN_PROJECTBASEDIR=${MAVEN_BASEDIR:-"$BASE_DIR"}

MAVEN_OPTS="$(concat_lines "$MAVEN_PROJECTBASEDIR/.mvn/jvm.config") $MAVEN_OPTS"

# Download the maven-wrapper.jar if it's not already downloaded.
wrapperJarPath="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
if [ -r "$wrapperJarPath" ]; then
  :
else
  wrapperUrl=$(grep distributionUrl "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties" | sed 's/.*=//;s/\r//')
  jarUrl=$(grep wrapperUrl "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties" | sed 's/.*=//;s/\r//')
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$wrapperJarPath" "$jarUrl"
  elif command -v wget >/dev/null 2>&1; then
    wget -q -O "$wrapperJarPath" "$jarUrl"
  else
    echo "ERROR: Neither curl nor wget is available. Cannot download maven-wrapper.jar."
    exit 1
  fi
fi

JAVA_HOME_CANDIDATE=$(java -XshowSettings:property -version 2>&1 | grep 'java.home' | sed 's/.*= //')
if [ -n "$JAVA_HOME_CANDIDATE" ]; then
  JAVA_HOME=$JAVA_HOME_CANDIDATE
fi

JAVA_CMD="${JAVA_HOME}/bin/java"
if [ ! -x "$JAVA_CMD" ]; then
  JAVA_CMD="java"
fi

exec "$JAVA_CMD" \
  $MAVEN_OPTS \
  -classpath "$wrapperJarPath" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
